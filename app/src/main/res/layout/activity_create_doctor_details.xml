<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp">

    <!-- Header -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow_back"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/create_account"
        android:textColor="@color/text_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/ivBack"
        app:layout_constraintBottom_toBottomOf="@id/ivBack"
        app:layout_constraintStart_toEndOf="@id/ivBack"
        android:layout_marginStart="16dp"/>

    <!-- Progress bar -->
    <LinearLayout
        android:id="@+id/llProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/ivBack">
        <View
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_soft_blue"
            android:backgroundTint="@color/primary_blue"
            android:layout_marginEnd="4dp"/>
        <View
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_circle_soft_blue"
            android:backgroundTint="@color/primary_blue"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/llProgress"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/doctor_details"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/patient_details_desc"
                android:textColor="@color/text_grey"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Name -->
            <TextView
                android:id="@+id/tvNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvDesc"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="@string/full_name_hint"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="16dp"
                android:textColorHint="#94A3B8"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvNameLabel"/>

            <!-- Email -->
            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etName"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="@string/full_name_hint"
                android:text="john@example.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="16dp"
                android:textColorHint="#94A3B8"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"/>

            <!-- Password -->
            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etEmail"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="@string/password_hint"
                android:inputType="textPassword"
                android:background="@drawable/bg_input"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="16dp"
                android:textColorHint="#94A3B8"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"/>

            <!-- Specialization -->
            <TextView
                android:id="@+id/tvSpecLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/specialization"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etSpec"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="@string/specialization_hint"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="16dp"
                android:textColorHint="#94A3B8"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvSpecLabel"/>

            <!-- License Number -->
            <TextView
                android:id="@+id/tvLicenseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/license_number"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etSpec"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etLicense"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="@string/license_number_hint"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="16dp"
                android:textColorHint="#94A3B8"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvLicenseLabel"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etLicense">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="@string/back"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    app:backgroundTint="@color/app_bg"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="0dp"
                    android:layout_weight="1.5"
                    android:layout_height="56dp"
                    android:text="@string/register"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/primary_blue"
                    app:cornerRadius="12dp"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
