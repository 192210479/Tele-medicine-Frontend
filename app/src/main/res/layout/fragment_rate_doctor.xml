<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface_bg">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CBD5E1"
        android:layout_marginBottom="20dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvRateTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rate Doctor"
        android:textColor="@color/text_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="How was your experience?"
        android:textColor="#64748B"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 5 Star Rating Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivRateStar1"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/ivRateStar2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/ivRateStar3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/ivRateStar4"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/ivRateStar5"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Optional Review Text -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Write a review (optional)"
        app:boxStrokeColor="@color/primary_blue"
        app:hintTextColor="@color/text_grey"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:inputType="textMultiLine" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitRating"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Submit Rating"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="@color/primary_blue"
        app:cornerRadius="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Skip -->
    <TextView
        android:id="@+id/tvSkipRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Skip"
        android:textColor="#64748B"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
