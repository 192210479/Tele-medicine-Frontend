<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface_bg"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <View
        android:id="@+id/vHeaderDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/llHeader"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/vHeaderDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Avatar -->
            <FrameLayout
                android:id="@+id/cvAvatarEdit"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    app:cardCornerRadius="44dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:layout_gravity="top|start">
                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/bg_image_mock"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Edit Icon -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="@color/primary_blue"
                    android:elevation="4dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        app:tint="@color/white"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_soft_gray_12dp"
                android:backgroundTint="@color/white"
                android:text="John Doe"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                app:elevation="1dp"/>

            <!-- Email Address (Read-only as per backend limitation) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address (Locked)"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_soft_gray_12dp"
                android:backgroundTint="#F1F5F9"
                android:text="krishna@gmail.com"
                android:textColor="@color/text_grey"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                app:elevation="0dp"
                android:focusable="false"
                android:clickable="false"
                android:inputType="textEmailAddress"/>

            <!-- Age and Gender -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textColor="@color/text_grey"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="@color/white"
                        android:text="28"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:paddingHorizontal="16dp"
                        app:elevation="1dp"
                        android:inputType="number"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gender"
                        android:textColor="@color/text_grey"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:id="@+id/llGender"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="@color/white"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:elevation="1dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/tvGender"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Male"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_down"
                            app:tint="@color/text_dark"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Phone Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_soft_gray_12dp"
                android:backgroundTint="@color/white"
                android:text="+1 234 567 8900"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                app:elevation="1dp"
                android:inputType="phone"/>

            <!-- Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_soft_gray_12dp"
                android:backgroundTint="@color/white"
                android:text="123 Main St, New York, NY"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp"
                app:elevation="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Changes"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="12dp"
                android:elevation="0dp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include layout="@layout/layout_patient_bottom_nav"
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
