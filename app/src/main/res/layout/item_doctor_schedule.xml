<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- TIME BLOCK -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:minWidth="56dp">

                <TextView
                    android:id="@+id/tvApptTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="09:00" />

                <TextView
                    android:id="@+id/tvApptAMPM"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:text="AM" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="16dp"
                android:background="#E2E8F0" />

            <!-- PATIENT INFO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Patient Name" />

                <TextView
                    android:id="@+id/tvConsultationType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    tools:text="Video Consultation" />

                <TextView
                    android:id="@+id/tvApptId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvApptDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- STATUS CHIP -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="upcoming" />
            </LinearLayout>
        </LinearLayout>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewReports"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:text="Reports"
                android:textAllCaps="false"
                android:textColor="#64748B"
                android:textSize="13sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartConsultation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:text="Start Call"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:backgroundTint="#2F80ED"
                app:cornerRadius="8dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
