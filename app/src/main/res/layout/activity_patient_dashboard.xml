<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:scrollbars="none">

        <!-- Ensure padding limits overlap -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_image_mock"
                    android:scaleType="centerCrop"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning,"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                app:layout_constraintTop_toTopOf="@id/cvAvatar"
                app:layout_constraintStart_toEndOf="@id/cvAvatar"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                app:layout_constraintStart_toStartOf="@id/tvGreeting"/>

            <!-- Notification Container -->
            <FrameLayout
                android:id="@+id/flNotifications"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/cvAvatar">
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_soft_gray"
                    android:backgroundTint="#F8FAFC"
                    android:elevation="1dp"/>
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:elevation="2dp"
                    android:src="@drawable/ic_bell_thin"/>
                <View
                    android:id="@+id/vNotificationBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="10dp"
                    android:elevation="3dp"
                    android:background="@drawable/bg_badge_red"/>
            </FrameLayout>

            <!-- Emergency Help Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/surface_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FECACA"
                app:layout_constraintTop_toBottomOf="@id/cvAvatar">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    
                    <ImageView
                        android:id="@+id/ivWarning"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/bg_icon_red"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_warning_triangle_white"
                        app:layout_constraintTop_toTopOf="@id/ivWarning"
                        app:layout_constraintBottom_toBottomOf="@id/ivWarning"
                        app:layout_constraintStart_toStartOf="@id/ivWarning"
                        app:layout_constraintEnd_toEndOf="@id/ivWarning"/>

                    <TextView
                        android:id="@+id/tvEmergencyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency Help"
                        android:textColor="@color/red_danger"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="@id/ivWarning"
                        app:layout_constraintStart_toEndOf="@id/ivWarning"
                        android:layout_marginStart="16dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Call ambulance, contacts &amp; hospitals"
                        android:textColor="@color/red_danger"
                        android:alpha="0.8"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/tvEmergencyTitle"
                        app:layout_constraintStart_toStartOf="@id/tvEmergencyTitle"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/red_danger"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Daily Health Tip Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvHealthTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F0F9FF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0F2FE"
                app:layout_constraintTop_toBottomOf="@id/cvEmergency">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/ivHealth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/bg_circle_soft_blue_small"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                    
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_pulse_blue"
                        app:layout_constraintTop_toTopOf="@id/ivHealth"
                        app:layout_constraintBottom_toBottomOf="@id/ivHealth"
                        app:layout_constraintStart_toStartOf="@id/ivHealth"
                        app:layout_constraintEnd_toEndOf="@id/ivHealth"/>

                    <TextView
                        android:id="@+id/tvHealthTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Health Tip"
                        android:textColor="@color/primary_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="@id/ivHealth"
                        app:layout_constraintStart_toEndOf="@id/ivHealth"
                        android:layout_marginStart="16dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Drink at least 8 glasses of water today to stay hydrated and boost your immunity."
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp"
                        android:alpha="0.85"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvHealthTitle"
                        app:layout_constraintStart_toStartOf="@id/tvHealthTitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="6dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4 Quick Actions -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/llQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/cvHealthTip">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="8dp">

                    <!-- Book -->
                    <LinearLayout android:id="@+id/llQuickBook" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_circle_soft_blue_small" android:alpha="0.6"/>
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_calendar_blue_exact" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Book" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Upload -->
                    <LinearLayout android:id="@+id/llQuickUpload" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_circle_soft_blue_small" android:alpha="0.6"/>
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_upload_exact" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upload" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Find Doctor -->
                    <LinearLayout android:id="@+id/itemFindDoctor" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_circle_soft_blue_small" android:alpha="0.6"/>
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_search_exact" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find Doctor" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Support -->
                    <LinearLayout android:id="@+id/itemSupport" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_circle_soft_blue_small" android:alpha="0.6"/>
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_headphones_exact" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Support" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvServices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Services"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/llQuickActions"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- GridLayout for Services - Elevated Cards -->
            <GridLayout
                android:id="@+id/glServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginTop="16dp"
                android:useDefaultMargins="true"
                app:layout_constraintTop_toBottomOf="@id/tvServices">

                <!-- 1. Book Appointment -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemBook"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_blue_rounded">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_calendar_white"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Book\nAppointment" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Upcoming -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemUpcoming"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_green">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_clock_white"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upcoming\n" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Prescriptions -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemPrescriptions"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_orange">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_document_white" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prescriptions\n" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. History -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemHistory"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_purple">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_pulse_white_main"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History\n" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Medical Records -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemMedicalRecords"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_indigo">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_folder_white" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medical\nRecords" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 6. Reminders -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemReminders"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_pink">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bell_white"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reminders\n" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 7. Emergency -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemEmergency"
                    android:layout_columnWeight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_margin="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="16dp">
                        <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_red">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_warning_triangle_white"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emergency\n" android:textAlignment="center" android:textColor="@color/text_dark" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Next Appointment -->
            <TextView
                android:id="@+id/tvNextAppt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Appointment"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/glServices"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvSeeAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See All"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvNextAppt"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNextAppt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvNextAppt">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/llDateBox"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_light_blue_rounded"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct"
                            android:textColor="@color/primary_blue"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24"
                            android:textColor="@color/primary_blue"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        app:layout_constraintTop_toTopOf="@id/llDateBox"
                        app:layout_constraintBottom_toBottomOf="@id/llDateBox"
                        app:layout_constraintStart_toEndOf="@id/llDateBox"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow">
                        
                        <TextView
                            android:id="@+id/tvApptDoc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doctor"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvApptSpec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cardiologist • 10:00 AM"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#94A3B8"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
