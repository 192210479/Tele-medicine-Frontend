<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/surface_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:id="@+id/flIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_circle_icon"
                android:backgroundTint="#EFF6FF">
                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_pill"
                    app:tint="@color/primary_blue"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:id="@+id/tvMedicineName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medicine Name"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvMedicineDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Details"
                    android:textColor="@color/text_grey"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_time"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_clock_white"
                    app:tint="@color/text_grey"/>
                <TextView
                    android:id="@+id/tvReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00 AM"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <View android:id="@+id/vDivider" android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginBottom="16dp" android:layout_marginHorizontal="-20dp"/>

        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Skip"
                android:textColor="@color/text_dark"
                android:textAllCaps="false"
                app:backgroundTint="@color/white"
                app:cornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                android:layout_marginEnd="8dp"
                android:elevation="0dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkTaken"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Mark Taken"
                android:textColor="@color/white"
                android:textAllCaps="false"
                app:backgroundTint="#22C55E"
                app:cornerRadius="12dp"
                android:layout_marginStart="8dp"
                android:elevation="0dp"
                app:strokeWidth="0dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llTakenBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_taken"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_gravity="end"
            android:visibility="gone">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_check"
                app:tint="#16A34A"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Taken"
                android:textColor="#16A34A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llSkippedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_skipped"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_gravity="end"
            android:visibility="gone">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_plus"
                android:rotation="45"
                app:tint="@color/text_grey"/>
            <TextView
                android:id="@+id/tvSkippedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ Skipped"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
