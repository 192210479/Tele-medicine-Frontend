<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:backgroundTint="#FFFFFF"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Patient Data"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"/>
        <ImageView
            android:id="@+id/ivClosePanel"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_close"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/tabInfo"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvTabInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="info"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>
            <View
                android:id="@+id/indicatorInfo"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/primary_blue"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvTabHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="history"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>
            <View
                android:id="@+id/indicatorHistory"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#F1F5F9" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabReports"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvTabReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="reports"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>
            <View
                android:id="@+id/indicatorReports"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#F1F5F9" />
        </LinearLayout>
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp">

        <!-- INFO TAB -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vitals"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Vitals Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_rounded_16dp"
                            android:backgroundTint="#F0F9FF"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BP"
                                android:textColor="#3B82F6"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="120/80"
                                android:textColor="@color/text_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_rounded_16dp"
                            android:backgroundTint="#FFF1F2"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Heart Rate"
                                android:textColor="#EF4444"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="72 bpm"
                                android:textColor="@color/text_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_rounded_16dp"
                            android:backgroundTint="#F0FDF4"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Temp"
                                android:textColor="#10B981"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="98.6°F"
                                android:textColor="@color/text_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_rounded_16dp"
                            android:backgroundTint="#FFF7ED"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Weight"
                                android:textColor="#F97316"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="65 kg"
                                android:textColor="@color/text_dark"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Symptoms"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Chips layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Headache"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nausea"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fatigue"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"/>
                </LinearLayout>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dizziness"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- HISTORY TAB -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_soft_gray_12dp"
                    android:backgroundTint="#F8FAFC"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Past Consultation"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Checkup - Sep 12, 2023"
                        android:textColor="@color/text_grey"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prescribed Paracetamol 500mg"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                
            </LinearLayout>
        </ScrollView>

        <!-- REPORTS TAB -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">
                
                <!-- Upload dashed box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="@drawable/bg_empty_dash">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_upload_blue"
                        app:tint="#64748B"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Report"
                        android:textColor="#64748B"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF, JPG, PNG"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rounded_soft_gray_12dp"
                    android:backgroundTint="#F8FAFC"
                    android:padding="16dp"
                    android:layout_marginTop="16dp">
                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#E0F2FE">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_document"
                            app:tint="@color/primary_blue"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Blood Test - Oct 2023"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rounded_soft_gray_12dp"
                    android:backgroundTint="#F8FAFC"
                    android:padding="16dp"
                    android:layout_marginTop="12dp">
                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_rounded_soft_gray_12dp"
                        android:backgroundTint="#E0F2FE">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_document"
                            app:tint="@color/primary_blue"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="ECG Report - Sep 2023"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </ViewFlipper>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:background="@color/surface_bg">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreatePrescription"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Prescription"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"
            android:elevation="0dp"
            app:strokeWidth="0dp"/>
    </LinearLayout>

</LinearLayout>
