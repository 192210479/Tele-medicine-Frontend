<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface_bg"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_dark"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consultation"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDoctor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="@color/surface_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/img_doctor_sarah"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/Corner16ImageView" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDoctorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doctor"
                        android:textColor="@color/text_dark"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSpeciality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_grey"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preparing"
                    android:textColor="#C2410C"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_pill_grey"
                    android:backgroundTint="#FFF7ED"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_light_blue_rounded"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clock_white"
                    app:tint="@color/primary_blue"/>

                <TextView
                    android:id="@+id/tvTimerHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Waiting: 0:00"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardDoctor"
        app:layout_constraintBottom_toTopOf="@id/btnWaiting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/bg_circle_soft_blue"
            app:tint="@color/primary_blue"
            android:alpha="0.2"/>
            
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_clock_white"
            app:tint="@color/primary_blue"
            android:layout_marginTop="-84dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:text="Waiting for Doctor"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Please wait while the doctor prepares for your consultation"
            android:textColor="@color/text_grey"
            android:textSize="14sp"
            android:textAlignment="center"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWaiting"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:text="Waiting for Doctor..."
        android:textAllCaps="false"
        android:textStyle="bold"
        android:enabled="false"
        app:cornerRadius="12dp"
        app:backgroundTint="#7FB8ED"
        app:icon="@drawable/ic_video_white"
        app:iconPadding="8dp"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toTopOf="@id/llQuickActions"/>

    <LinearLayout
        android:id="@+id/llQuickActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:text="Chat"
            android:textAllCaps="false"
            android:textColor="@color/primary_blue"
            app:cornerRadius="12dp"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/white"
            app:icon="@drawable/ic_chat_bubble_outline"
            app:iconTint="@color/primary_blue"
            app:iconPadding="8dp"
            app:iconGravity="textStart"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:text="Share Reports"
            android:textAllCaps="false"
            android:textColor="@color/primary_blue"
            app:cornerRadius="12dp"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/white"
            app:icon="@drawable/ic_upload_white"
            app:iconTint="@color/primary_blue"
            app:iconPadding="8dp"
            app:iconGravity="textStart"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
