<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <!-- Top Left Heart -->
    <ImageView
        android:id="@+id/ivHeartTopLeft"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_heart_outline"
        android:layout_marginTop="120dp"
        android:layout_marginStart="44dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Right Stethoscope -->
    <ImageView
        android:id="@+id/ivStethoscope"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_stethoscope"
        android:layout_marginTop="220dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Center Icon Box -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_heartbeat"
            android:elevation="12dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_heartbeat"
                app:tint="@color/primary_blue" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTelemedicine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/telemedicine"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <TextView
            android:id="@+id/tvRemoteCare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_care"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvHealthcare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/healthcare_fingertips"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <!-- Bottom Left Pill -->
    <ImageView
        android:id="@+id/ivPill"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_pill"
        android:layout_marginBottom="280dp"
        android:layout_marginStart="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Bottom Right Heart -->
    <ImageView
        android:id="@+id/ivHeartBottomRight"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_heart_outline"
        android:layout_marginBottom="200dp"
        android:layout_marginEnd="44dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/tvVersion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/dot_white"
            android:layout_marginEnd="8dp" />
        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/dot_white"
            android:alpha="0.4"
            android:layout_marginEnd="8dp"/>
        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/dot_white"
            android:alpha="0.4" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/version_text"
        android:textColor="#B0BEC5"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
