<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- LEFT: PATIENT AVATAR -->
        <ImageView
            android:id="@+id/ivPatientAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_circle_avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_placeholder"
            android:contentDescription="Patient Avatar" />

        <!-- CENTER: PATIENT INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1E293B"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                tools:text="Patient Name" />

            <TextView
                android:id="@+id/tvConsultationType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                tools:text="Video Call" />

            <TextView
                android:id="@+id/tvApptDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#2F80ED"
                android:textSize="13sp"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                tools:text="2026-03-19 09:00" />
            
            <TextView
                android:id="@+id/tvApptId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvApptDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <!-- RIGHT: STATUS & ACTION -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textAllCaps="true"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="UPCOMING" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartConsultation"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:text="Start Call"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="#2F80ED"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkCompleted"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:text="Complete"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="#059669"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewReports"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Details"
                android:textAllCaps="false"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
