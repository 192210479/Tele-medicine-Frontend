<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote Video (Patient) -->
    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1E293B" />

    <!-- Top Overlay Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_gradient_top_black">

        <LinearLayout
            android:id="@+id/llTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_red" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:03"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/llTimer"
            app:layout_constraintEnd_toStartOf="@id/llSignal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctor"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpeciality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#94A3B8"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llSignal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivSignal"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_signal"
                app:tint="#22C55E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="HD"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Local Video (Doctor) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvLocalVideo"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/localVideoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#334155" />

        <ImageView
            android:id="@+id/ivLocalPlaceholder"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_video_off"
            android:visibility="gone"
            app:tint="#D1D5DB" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Patient Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvPatientInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="80dp"
        app:cardBackgroundColor="#CC1E293B"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivPatientAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/bg_circle_soft_blue" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPatientDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#E2E8F0"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_red_alpha"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="High Fever"
                    android:textColor="#FCA5A5"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_pill_blue_alpha"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Migraine"
                    android:textColor="#93C5FD"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Control Bar -->
    <HorizontalScrollView
        android:id="@+id/hsvControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@android:color/transparent"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/llControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Mic -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_mic"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Mute Mic"/>

            <!-- Camera -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_video"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Toggle Video"/>

            <!-- Switch -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_flip_camera"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Switch Camera"/>

            <!-- END CALL (Centered Emphasis) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabEndCall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:fabCustomSize="60dp"
                app:maxImageSize="30dp"
                android:src="@drawable/ic_call_end"
                app:tint="#FFFFFF"
                app:backgroundTint="#EF4444"
                app:borderWidth="0dp"
                app:elevation="4dp"
                android:contentDescription="End Call"/>

            <!-- Speaker -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSpeaker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_speaker"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Speaker"/>

            <!-- Chat -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_message"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Chat"/>

            <!-- Upload -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabUpload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_upload_white"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Upload File"/>

            <!-- Patient Info -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabPatientData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:fabCustomSize="50dp"
                app:maxImageSize="24dp"
                android:src="@drawable/ic_info"
                app:tint="#FFFFFF"
                app:backgroundTint="#B3000000"
                app:borderWidth="0dp"
                app:elevation="0dp"
                android:contentDescription="Patient Records"/>

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
