<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <!-- Skip Button -->
    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/skip"
        android:textColor="@color/text_light"
        android:textSize="16sp"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Illustration Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clIllustration"
        android:layout_width="320dp"
        android:layout_height="320dp"
        app:layout_constraintTop_toBottomOf="@id/tvSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintVertical_bias="0.3">

        <!-- Outer soft circle -->
        <View
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_circle_soft_teal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:alpha="0.1"/>

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="128dp"
            android:layout_height="128dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#E0F5EB"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_document_green" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Decorative Dots -->
        <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/dot_teal" app:layout_constraintStart_toStartOf="parent" app:layout_constraintBottom_toBottomOf="parent" android:layout_marginStart="40dp" android:layout_marginBottom="60dp"/>
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/dot_blue" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" android:layout_marginEnd="50dp" android:layout_marginTop="40dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_orange" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent" android:layout_marginEnd="60dp" android:layout_marginBottom="100dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Text content -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_2_title"
        android:textColor="@color/text_dark"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/tvDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_2_desc"
        android:textColor="@color/text_grey"
        android:textSize="14sp"
        android:textAlignment="center"
        android:lineHeight="22sp"
        android:layout_marginBottom="64dp"
        android:layout_marginHorizontal="48dp"
        app:layout_constraintBottom_toTopOf="@id/llDots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Indicators -->
    <LinearLayout
        android:id="@+id/llDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_pill_grey"
            android:layout_marginEnd="8dp"/>
        <View
            android:layout_width="32dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_pill_blue"
            android:layout_marginEnd="8dp"/>
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_pill_grey"/>
    </LinearLayout>

    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/next"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="24dp"
        app:icon="@drawable/ic_arrow_right"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:backgroundTint="@color/primary_blue"
        app:cornerRadius="18dp"
        android:insetBottom="0dp"
        android:insetTop="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:stateListAnimator="@animator/button_scale" />

</androidx.constraintlayout.widget.ConstraintLayout>
