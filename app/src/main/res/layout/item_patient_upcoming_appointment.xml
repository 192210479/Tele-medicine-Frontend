<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- DOCTOR PROFILE IMAGE -->
        <ImageView
            android:id="@+id/ivDoctorImage"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_soft_gray"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/ic_user_placeholder" />

        <!-- DOCTOR INFO -->
        <LinearLayout
            android:id="@+id/llDoctorData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/ivDoctorImage"
            app:layout_constraintEnd_toStartOf="@id/tvPatientStatusPill"
            app:layout_constraintStart_toEndOf="@id/ivDoctorImage"
            app:layout_constraintTop_toTopOf="@id/ivDoctorImage">

            <TextView
                android:id="@+id/tvPatientDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Doctor Name"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPatientSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Specialization"
                android:textColor="@color/text_light"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- STATUS CHIP -->
        <TextView
            android:id="@+id/tvPatientStatusPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_grey"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Scheduled"
            android:textColor="@color/text_grey"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivDoctorImage" />

        <View
            android:id="@+id/patientDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#F1F5F9"
            app:layout_constraintTop_toBottomOf="@id/ivDoctorImage" />

        <!-- DATE AND TIME ROW -->
        <LinearLayout
            android:id="@+id/llPatientDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="1"
            app:layout_constraintTop_toBottomOf="@id/patientDivider">

            <!-- Calendar Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.45"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar_blue"
                    app:tint="@color/primary_blue" />

                <TextView
                    android:id="@+id/tvPatientDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Date"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Time Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.55"
                android:gravity="center_vertical|end"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clock_outline"
                    app:tint="@color/primary_blue" />

                <TextView
                    android:id="@+id/tvPatientTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Time"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:id="@+id/actionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/llPatientDateTime">

            <!-- JOIN CONSULTATION BUTTON -->
            <Button
                android:id="@+id/btnJoin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Join Consultation"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#2F80ED"
                android:visibility="gone"
                app:cornerRadius="12dp" />

            <!-- VIEW DETAILS BUTTON -->
            <Button
                android:id="@+id/btnDetails"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="View Details"
                android:textAllCaps="false"
                android:background="@drawable/outline_button"
                android:textColor="#2F80ED"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
