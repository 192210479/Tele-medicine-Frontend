<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:fillViewport="true"
        android:scrollbars="none">

        <!-- Everything in a vertical linear layout for easier stacked UI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header (White BG) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_bg"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_dark"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/emergency_help"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivBack"
                    android:layout_marginStart="16dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Red Banner Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EF4444"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you are in a life-threatening situation, call for an\nambulance immediately."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:alpha="0.9"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCallAmbulance"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Call Ambulance (102)"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_phone"
                    app:iconTint="#EF4444"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="20dp"
                    android:elevation="2dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="2">

                    <!-- Share Location -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareLocation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:text="Share Location"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        app:icon="@drawable/ic_location"
                        app:iconTint="@color/white"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/white"
                        app:strokeWidth="1dp"
                        app:cornerRadius="12dp"
                        android:layout_marginEnd="6dp"
                        android:alpha="0.95"/>

                    <!-- Emergency Contact -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmergencyContact"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:text="Emergency Contact"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        app:icon="@drawable/ic_phone"
                        app:iconTint="@color/white"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/white"
                        app:strokeWidth="1dp"
                        app:cornerRadius="12dp"
                        android:layout_marginStart="6dp"
                        android:alpha="0.95"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Bottom Content Group -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- Emergency Contacts Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_heart_red"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency Contacts"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- Dynamic Contacts Container -->
                <LinearLayout
                    android:id="@+id/llEmergencyContactsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dynamic items will be added here -->
                    
                    <!-- Fallback if no contacts -->
                    <TextView
                        android:id="@+id/tvNoContacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No emergency contacts added yet."
                        android:textColor="@color/text_grey"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddEmergencyContact"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Add Emergency Contact"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_plus"
                    app:iconTint="@color/primary_blue"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/white"
                    app:strokeColor="@color/primary_blue"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Nearby Hospitals -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_hospital_building"
                        app:tint="@color/primary_blue"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Nearby Hospitals"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>
                    
                    <ImageView
                        android:id="@+id/ivRefreshHospitals"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_popup_sync"
                        app:tint="@color/primary_blue"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>

                <!-- Dynamic Hospitals Container -->
                <LinearLayout
                    android:id="@+id/llHospitalsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dynamic items will be added here -->
                </LinearLayout>

                <!-- Safety tips -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#F0F9FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0F2FE"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Safety Tips"
                            android:textColor="@color/primary_blue"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•   Stay calm and do not panic." android:textColor="@color/primary_blue" android:alpha="0.85" android:textSize="12sp" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•   Keep your location services on." android:textColor="@color/primary_blue" android:alpha="0.85" android:textSize="12sp" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•   Have your medical ID ready on your phone." android:textColor="@color/primary_blue" android:alpha="0.85" android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Mock -->
    <include layout="@layout/layout_patient_bottom_nav"
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
