<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_white"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvDoc"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:id="@+id/ivDoc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_image_mock"
            android:scaleType="centerCrop"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvDocName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dr. Sarah Johnson"
        android:textColor="@color/text_dark"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/cvDoc"
        app:layout_constraintStart_toEndOf="@id/cvDoc"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="14dp"/>

    <TextView
        android:id="@+id/tvDocSpec"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cardiologist"
        android:textColor="@color/primary_blue"
        android:textSize="14sp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvDocName"
        app:layout_constraintStart_toStartOf="@id/tvDocName"/>

    <TextView
        android:id="@+id/tvHospitalName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simats Medical Center"
        android:textColor="@color/text_grey"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvDocSpec"
        app:layout_constraintStart_toStartOf="@id/tvDocName"/>

    <LinearLayout
        android:id="@+id/llMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvHospitalName"
        app:layout_constraintStart_toStartOf="@id/tvDocName"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:id="@+id/tvExperience"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8 Yrs Exp"
            android:textColor="@color/text_dark"
            android:textSize="11sp"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"/>

        <TextView
            android:id="@+id/tvFee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹500"
            android:textColor="#10B981"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(124 reviews)"
        android:textColor="@color/text_grey"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/llMeta"
        app:layout_constraintStart_toStartOf="@id/tvDocName"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBook"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Book Appointment"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="#10B981"
        app:cornerRadius="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvDoc"/>

</androidx.constraintlayout.widget.ConstraintLayout>
